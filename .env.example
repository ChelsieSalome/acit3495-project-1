# ============================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=project1
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_HOST=mysql                   # Keep as 'mysql' for Docker, change to 'localhost' if running locally

# --- MongoDB ---
MONGO_URI=mongodb://mongodb:27017  # Keep as 'mongodb' for Docker, change to 'localhost' if running locally
MONGO_DB=analytics_db
ANALYTICS_COLLECTION=analytics

# --- Auth Service ---
JWT_SECRET=change_this_to_a_strong_secret
TOKEN_TTL_SECONDS=3600
AUTH_SERVICE_PORT=5001

# --- Enter Data App ---
ENTER_DATA_PORT=5000
AUTH_SERVICE_URL=http://auth-service:5001  # Change 'auth-service' to 'localhost' if running locally

# --- Analytics Service ---
ANALYTICS_PORT=5004
FLASK_DEBUG=false
